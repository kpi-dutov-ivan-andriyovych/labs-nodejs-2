<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Склад Бригади №5</title>
    <link rel="stylesheet" href="/css/team.css">
    <link rel="stylesheet" href="/css/index.css">
</head>
<body>

<%- include('partials/nav') %>

<main>
    <h1 class="team-title">Склад Бригади №5</h1>

    <div class="member-grid">
        <% students.forEach(student => { %>
            <div class="member-card">
                <img src="<%= student.avatar %>" alt="Avatar" class="member-avatar">
                
                <h3 class="member-name"><%= student.name %></h3>
                <p class="member-role"><%= student.role %></p>
                
                <div class="member-action">
                    <a href="/student/<%= student.id %>" class="profile-link">
                        [ view profile ]
                    </a>
                </div>
            </div>
        <% }); %>
    </div>
</main>

<footer>
    <hr class="footer-divider">
    <p class="footer-text">Репозиторій проекту: <a href="https://github.com/kpi-dutov-ivan-andriyovych/labs-nodejs-2" target="_blank" class="footer-link">GitHub</a></p>
</footer>

</body>
</html>